# Copy this to .env and fill in your values
# NEVER commit .env to git!

# Claude via Vertex AI (notas-personal gcloud config)
CLAUDE_PROVIDER=vertex
GOOGLE_CLOUD_PROJECT=notaslaveai-prod
GOOGLE_CLOUD_REGION=us-east5

# OR Claude direct API (if not using Vertex)
# ANTHROPIC_API_KEY=your_api_key_here

# Twelve Data API key for real-time Gold/Silver spot data
# Sign up free: https://twelvedata.com (works in India)
TWELVEDATA_API_KEY=your_api_key_here

# Telegram Alerts
# 1. Create bot: Talk to @BotFather on Telegram, send /newbot
# 2. Get chat ID: Visit https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Optional: Override defaults
# CLAUDE_MODEL=claude-sonnet-4-20250514
# CLAUDE_MIN_CONFIDENCE=7
# API_PORT=8000
# INITIAL_BALANCE=100000
